{
  "templateHtml": "<div><h2>Report for @Model.name</h2><p>Date: @Model.date</p></div>",
  "templateCss": "body { font-family: Arial, sans-serif; }",
  "data": {
    "name": "Monthly Summary",
    "date": "2026-02-20"
  },
  "attachments": [
    { "key": "docPart", "fileType": "docx" },
    { "key": "sheetPart", "fileType": "xlsx" },
    { "key": "csvPart", "fileType": "csv" },
    { "key": "imagePart", "fileType": "png" },
    { "key": "textPart", "fileType": "txt" },
    { "key": "pdfPart", "fileType": "pdf" }
  ],
  "renderOptions": {
    "paperSize": "A4",
    "orientation": "Portrait",
    "includeHeader": true,
    "headerText": "Composed Report",
    "includeFooter": true,
    "footerText": "Internal"
  },
  "postProcessOptions": {
    "enablePageNumbers": true,
    "watermarkText": "DRAFT",
    "headerText": "Company Confidential",
    "footerText": "Generated by PDF Composer"
  }
}
